{
  "entities": {
    "Enterprise": {
      "title": "Enterprise",
      "description": "Represents a company using the system.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Company name" },
        "adminUsers": { "type": "array", "items": { "type": "string" }, "description": "List of admin UIDs" },
        "projectAttributes": { "type": "array" },
        "lineItemAttributes": { "type": "array" },
        "costCodeAttributes": { "type": "array" },
        "subcontractAttributes": { "type": "array" },
        "changeAttributes": { "type": "array" },
        "riskAttributes": { "type": "array" },
        "procurementAttributes": { "type": "array" },
        "progressAttributes": { "type": "array" },
        "settings": { "type": "object", "description": "Enterprise-wide settings" }
      },
      "required": ["name", "adminUsers"]
    },
    "Project": {
      "title": "Project",
      "description": "A construction project within an enterprise.",
      "type": "object",
      "properties": {
        "enterpriseId": { "type": "string" },
        "projectName": { "type": "string" },
        "projectCode": { "type": "string" },
        "projectBudget": { "type": "number" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "reportingPeriods": { "type": "object" },
        "progressPeriods": { "type": "object" },
        "users": { "type": "object", "description": "Map of UID to role (e.g., 'admin', 'editor', 'viewer')" },
        "costCodeAttributes": { "type": "array" },
        "subcontractAttributes": { "type": "array" },
        "changeAttributes": { "type": "array" },
        "riskAttributes": { "type": "array" },
        "procurementAttributes": { "type": "array" },
        "progressAttributes": { "type": "array" },
        "lineItemAttributes": { "type": "array" }
      },
      "required": ["enterpriseId", "projectName", "projectCode"]
    },
    "Sheet": {
      "title": "Sheet",
      "description": "A forecasting sheet within a project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "sheetName": { "type": "string" },
        "forecastMethod": { "type": "string", "enum": ["commitment", "time-based"] },
        "version": { "type": "string" },
        "lockedStatus": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "users": { "type": "array", "items": { "type": "string" }, "description": "List of UIDs with access" }
      },
      "required": ["projectId", "sheetName", "forecastMethod"]
    },
    "ForecastRow": {
      "title": "Forecast Row",
      "description": "A single line item in a forecast sheet.",
      "type": "object",
      "properties": {
        "sheetId": { "type": "string" },
        "costCode": { "type": "string" },
        "description": { "type": "string" },
        "vendor": { "type": "string" },
        "budget": { "type": "number" },
        "committedCost": { "type": "number" },
        "actualCostToDate": { "type": "number" },
        "costToGo": { "type": "number" },
        "eac": { "type": "number" },
        "timePhasing": { "type": "object", "description": "Monthly forecast values" },
        "distributionMethod": { "type": "string", "enum": ["manual", "even", "front", "back", "custom"] }
      },
      "required": ["sheetId", "costCode"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Record of activities for security and compliance.",
      "type": "object",
      "properties": {
        "enterpriseId": { "type": "string" },
        "projectId": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "object" }
      },
      "required": ["enterpriseId", "userId", "action", "timestamp"]
    },
    "Invitation": {
      "title": "Invitation",
      "description": "A secure invitation for a user to join an enterprise.",
      "type": "object",
      "properties": {
        "enterpriseId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "token": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "expired"] },
        "invitedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["enterpriseId", "email", "token", "status", "invitedBy", "createdAt", "expiresAt"]
    },
    "CostCode": {
      "title": "Cost Code",
      "description": "A project-specific cost code with attributes.",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "User-defined cost code ID" },
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "activityId": { "type": "string", "description": "Reference to Schedule Activity ID" },
        "enterpriseAttributes": { "type": "object" },
        "projectAttributes": { "type": "object" },
        "eacMethod": { "type": "string", "enum": ["Manual", "Change Management", "ETC Details", "Sub-Contract Management"] },
        "sortOrder": { "type": "number" }
      },
      "required": ["code", "projectId", "sortOrder"]
    },
    "EtcDetail": {
      "title": "ETC Detail",
      "description": "A single line item in an ETC details breakdown.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "costCode": { "type": "string" },
        "activityId": { "type": "string", "description": "Reference to Schedule Activity ID" },
        "calendarId": { "type": "string", "description": "Reference to a project calendar" },
        "item": { "type": "string" },
        "description": { "type": "string" },
        "orderNumber": { "type": "string" },
        "udf1": { "type": "string" },
        "udf2": { "type": "string" },
        "udf3": { "type": "string" },
        "udf4": { "type": "string" },
        "qty": { "type": "number" },
        "unit": { "type": "string" },
        "rate": { "type": "number" },
        "phasingMethod": { "type": "string", "enum": ["Manual", "Auto-Phase"] },
        "phasingStartDate": { "type": "string", "format": "date" },
        "phasingEndDate": { "type": "string", "format": "date" },
        "phasingUnit": { "type": "string", "enum": ["Daily", "Weekly", "Monthly", "Total"] },
        "phasingQty": { "type": "number" },
        "periodValues": { "type": "object" },
        "sortOrder": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "costCode", "sortOrder", "createdAt"]
    },
    "Calendar": {
      "title": "Calendar",
      "description": "Enterprise or Project-specific working day calendar.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "enterpriseId": { "type": "string" },
        "name": { "type": "string" },
        "weekends": { "type": "array", "items": { "type": "number" }, "description": "0-6 (Sun-Sat)" },
        "holidays": { "type": "array", "items": { "type": "string", "format": "date" } }
      },
      "required": ["name"]
    },
    "SavedView": {
      "title": "Saved View",
      "description": "A personalized grid view configuration for a user.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "tableId": { "type": "string" },
        "columns": { "type": "array", "items": { "type": "string" } },
        "gridState": { "type": "array", "description": "Serialized AG-Grid column state" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "tableId", "columns", "userId", "createdAt"]
    },
    "ActualCost": {
      "title": "Actual Cost",
      "description": "A single transaction or record of actual expenditure.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "costCodeId": { "type": "string", "description": "Reference to a CostCode document ID" },
        "item": { "type": "string" },
        "description": { "type": "string" },
        "source": { "type": "string", "enum": ["MAN", "ACC", "FIN"] },
        "cost": { "type": "number" },
        "reportingPeriodId": { "type": "string", "description": "Reference to a reporting period ID" },
        "enterpriseAttributes": { "type": "object" },
        "projectAttributes": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "costCodeId", "cost", "reportingPeriodId", "createdAt"]
    },
    "BaselineBudget": {
      "title": "Baseline Budget",
      "description": "A single record of baseline budget breakdown.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "costCodeId": { "type": "string", "description": "Reference to a CostCode document ID" },
        "item": { "type": "string" },
        "description": { "type": "string" },
        "source": { "type": "string", "enum": ["EST", "CON", "BID"] },
        "amount": { "type": "number" },
        "reportingPeriodId": { "type": "string", "description": "Reference to a reporting period ID" },
        "enterpriseAttributes": { "type": "object" },
        "projectAttributes": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "costCodeId", "amount", "reportingPeriodId", "createdAt"]
    },
    "CostPhasing": {
      "title": "Cost Phasing",
      "description": "Time-phased budget or cost data for a cost code.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "costCodeId": { "type": "string" },
        "type": { "type": "string", "enum": ["baseline", "approved", "eac"] },
        "phasingSource": { "type": "string", "enum": ["Manual", "Auto", "ETC Details", "SubContract"] },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "distribution": { "type": "string", "enum": ["Even", "Bell Curve", "Front load", "Back load", "S-Curve"] },
        "periodValues": { "type": "object", "description": "Map of periodId to cost value" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "costCodeId", "type", "periodValues"]
    },
    "Subcontract": {
      "title": "Subcontract",
      "description": "Represents a subcontract agreement with a vendor.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "enterpriseId": { "type": "string" },
        "orderId": { "type": "string", "description": "User-defined Order ID (max 50)" },
        "orderName": { "type": "string" },
        "orderScope": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Complete", "On Hold"] },
        "paymentType": { "type": "string", "enum": ["LumpSum", "Schedule of Rates", "Re-measurable"] },
        "awardDate": { "type": "string", "format": "date" },
        "vendorId": { "type": "string" },
        "vendorName": { "type": "string" },
        "vendorUsers": { "type": "array", "items": { "type": "string" }, "description": "Emails of users with access" },
        "totalAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "enterpriseId", "orderId", "orderName", "status", "vendorId", "createdAt"]
    },
    "SubcontractLineItem": {
      "title": "Subcontract Line Item",
      "description": "A single line item in a subcontract agreement.",
      "type": "object",
      "properties": {
        "subcontractId": { "type": "string" },
        "projectId": { "type": "string" },
        "activityId": { "type": "string", "description": "Reference to Schedule Activity ID" },
        "itemNo": { "type": "string", "description": "Sequential ID (e.g., 001)" },
        "description": { "type": "string" },
        "qty": { "type": "number" },
        "unit": { "type": "string" },
        "rate": { "type": "number" },
        "total": { "type": "number" },
        "enterpriseAttributes": { "type": "object" },
        "projectAttributes": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subcontractId", "projectId", "itemNo", "description", "qty", "rate", "total", "createdAt"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A progress claim or invoice submitted against a subcontract.",
      "type": "object",
      "properties": {
        "subcontractId": { "type": "string" },
        "projectId": { "type": "string" },
        "invoiceId": { "type": "string", "description": "Sequential ID (e.g., 001)" },
        "description": { "type": "string" },
        "submittedDate": { "type": "string", "format": "date-time" },
        "certifiedDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Draft", "Submitted", "Certified", "Rejected"] },
        "initiator": { "type": "string", "description": "Email of the user who submitted" },
        "claimedAmount": { "type": "number" },
        "certifiedAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subcontractId", "projectId", "invoiceId", "status", "initiator", "createdAt"]
    },
    "InvoiceItem": {
      "title": "Invoice Item",
      "description": "A single line item in an invoice or progress claim.",
      "type": "object",
      "properties": {
        "invoiceId": { "type": "string" },
        "subcontractItemId": { "type": "string" },
        "itemNo": { "type": "string" },
        "qtyClaimedOrPercentage": { "type": "number" },
        "totalClaimed": { "type": "number" },
        "qtyCertifiedOrPercentage": { "type": "number" },
        "totalCertified": { "type": "number" },
        "comment": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["invoiceId", "subcontractItemId", "itemNo", "createdAt"]
    },
    "Risk": {
      "title": "Risk",
      "description": "Represents a project risk.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "riskId": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "Mitigated", "Closed", "Realized"] },
        "strategy": { "type": "string", "enum": ["Avoid", "Mitigate", "Transfer", "Accept"] },
        "exposure": { "type": "number", "description": "Total Initial EMV" },
        "mitigation": { "type": "number", "description": "Total Mitigation Cost" },
        "residualExposure": { "type": "number", "description": "Total Residual EMV" },
        "periodId": { "type": "string" },
        "enterpriseAttributes": { "type": "object" },
        "projectAttributes": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "riskId", "status", "createdAt", "updatedAt"]
    },
    "RiskRecord": {
      "title": "Risk Record",
      "description": "Represents the impact of a risk on a specific cost code.",
      "type": "object",
      "properties": {
        "riskId": { "type": "string" },
        "projectId": { "type": "string" },
        "costCodeId": { "type": "string" },
        "scope": { "type": "string" },
        "probability": { "type": "number" },
        "impactAmount": { "type": "number" },
        "mitigationCost": { "type": "number" },
        "residualProbability": { "type": "number" },
        "residualImpactAmount": { "type": "number" },
        "enterpriseAttributes": { "type": "object" },
        "projectAttributes": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["riskId", "projectId", "costCodeId", "probability", "impactAmount", "mitigationCost", "residualProbability", "residualImpactAmount", "createdAt", "updatedAt"]
    },
    "ProcurementStepDefinition": {
      "title": "Procurement Step Definition",
      "description": "Definition of a tracking step in the procurement process.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "enterpriseId": { "type": "string" },
        "name": { "type": "string" },
        "order": { "type": "number" },
        "isEnterpriseStandard": { "type": "boolean" }
      },
      "required": ["name", "order"]
    },
    "ProcurementItem": {
      "title": "Procurement Item",
      "description": "A procurement package with tracked steps.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "packageId": { "type": "string" },
        "description": { "type": "string" },
        "calendarId": { "type": "string" },
        "category": { "type": "string" },
        "stepData": { "type": "object", "description": "Map of step definition ID to step data" }
      },
      "required": ["projectId", "packageId", "description", "stepData"]
    },
    "ProgressPackage": {
      "title": "Progress Package",
      "description": "A high-level package for tracking physical progress.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "packageId": { "type": "string", "description": "Unique Package ID (max 20 chars)" },
        "description": { "type": "string" },
        "ruleOfCreditId": { "type": "string", "description": "Reference to the selected Rule of Credit" },
        "attributes": { "type": "object", "description": "Custom attribute values" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "packageId", "description"]
    },
    "ProgressItem": {
      "title": "Progress Item",
      "description": "A detailed item within a progress package.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "packageId": { "type": "string", "description": "Reference to parent packageId" },
        "itemId": { "type": "string", "description": "Unique Item ID within package" },
        "description": { "type": "string" },
        "costCodeId": { "type": "string", "description": "Reference to Project Cost Code" },
        "activityId": { "type": "string", "description": "Reference to Schedule Activity ID" },
        "totalQty": { "type": "number" },
        "unit": { "type": "string" },
        "plannedStartDate": { "type": "string", "format": "date" },
        "plannedEndDate": { "type": "string", "format": "date" },
        "phasingMethod": { "type": "string", "enum": ["Auto", "Manual"] },
        "phasingCurve": { "type": "string" },
        "currentStartDate": { "type": "string", "format": "date" },
        "currentEndDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "packageId", "itemId", "description"]
    },
    "ProgressReportingPeriod": {
      "title": "Progress Reporting Period",
      "description": "Weekly reporting periods for progress tracking.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "periodName": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Open", "Closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "periodName", "startDate", "endDate"]
    },
    "ProgressAttribute": {
      "title": "Progress Attribute",
      "description": "Custom attributes for progress tracking items.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "dropdown", "date", "number"] },
        "values": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      },
      "required": ["projectId", "title", "type"]
    },
    "RuleOfCredit": {
      "title": "Rule of Credit",
      "description": "Setup rules of credit types with detailed steps and weightings.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "ruleId": { "type": "string", "description": "Unique RoC ID (max 20 chars)" },
        "description": { "type": "string" },
        "packageId": { "type": "string", "description": "ID of the assigned package" },
        "userField1": { "type": "string", "description": "User defined field 1" },
        "userField2": { "type": "string", "description": "User defined field 2" },
        "userField3": { "type": "string", "description": "User defined field 3" },
        "userField4": { "type": "string", "description": "User defined field 4" },
        "userField5": { "type": "string", "description": "User defined field 5" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "orderNo": { "type": "number", "description": "Step Order No (max 10 chars decimal)" },
              "description": { "type": "string", "description": "Step Description (max 100 chars)" },
              "weight": { "type": "number", "description": "Step Weight decimal" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "ruleId", "description"]
    },
    "ScheduleItem": {
      "title": "Schedule Item",
      "description": "A single activity from a project schedule (P6/MS Project).",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "activityId": { "type": "string", "description": "Unique Activity ID from schedule" },
        "description": { "type": "string" },
        "currentStartDate": { "type": "string", "format": "date" },
        "currentEndDate": { "type": "string", "format": "date" },
        "plannedStartDate": { "type": "string", "format": "date" },
        "plannedEndDate": { "type": "string", "format": "date" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "activityId", "description"]
    }
  },
  "firestore": {
    "/scheduleItems/{itemId}": {
      "schema": "ScheduleItem",
      "description": "Master project schedule activities"
    },
    "/enterprises/{enterpriseId}": {
      "schema": "Enterprise",
      "description": "Enterprise root documents"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project documents"
    },
    "/sheets/{sheetId}": {
      "schema": "Sheet",
      "description": "Forecasting sheets"
    },
    "/sheets/{sheetId}/rows/{rowId}": {
      "schema": "ForecastRow",
      "description": "Rows within a sheet"
    },
    "/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "System-wide audit logs"
    },
    "/invitations/{invitationId}": {
      "schema": "Invitation",
      "description": "Secure invitations to join enterprises"
    },
    "/costCodes/{costCodeId}": {
      "schema": "CostCode",
      "description": "Project-specific cost codes"
    },
    "/etcDetails/{etcId}": {
      "schema": "EtcDetail",
      "description": "Detailed ETC breakdown items"
    },
    "/calendars/{calendarId}": {
      "schema": "Calendar",
      "description": "Project-specific calendars"
    },
    "/savedViews/{viewId}": {
      "schema": "SavedView",
      "description": "User-specific saved grid views"
