{
  "entities": {
    "Enterprise": {
      "title": "Enterprise",
      "description": "Represents a company using the system.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Company name" },
        "adminUsers": { "type": "array", "items": { "type": "string" }, "description": "List of admin UIDs" },
        "settings": { "type": "object", "description": "Enterprise-wide settings" }
      },
      "required": ["name", "adminUsers"]
    },
    "Project": {
      "title": "Project",
      "description": "A construction project within an enterprise.",
      "type": "object",
      "properties": {
        "enterpriseId": { "type": "string" },
        "projectName": { "type": "string" },
        "projectCode": { "type": "string" },
        "projectBudget": { "type": "number" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "users": { "type": "object", "description": "Map of UID to role (e.g., 'admin', 'editor', 'viewer')" }
      },
      "required": ["enterpriseId", "projectName", "projectCode"]
    },
    "Sheet": {
      "title": "Sheet",
      "description": "A forecasting sheet within a project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "sheetName": { "type": "string" },
        "forecastMethod": { "type": "string", "enum": ["commitment", "time-based"] },
        "version": { "type": "string" },
        "lockedStatus": { "type": "boolean" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "users": { "type": "array", "items": { "type": "string" }, "description": "List of UIDs with access" }
      },
      "required": ["projectId", "sheetName", "forecastMethod"]
    },
    "ForecastRow": {
      "title": "Forecast Row",
      "description": "A single line item in a forecast sheet.",
      "type": "object",
      "properties": {
        "sheetId": { "type": "string" },
        "costCode": { "type": "string" },
        "description": { "type": "string" },
        "vendor": { "type": "string" },
        "budget": { "type": "number" },
        "committedCost": { "type": "number" },
        "actualCostToDate": { "type": "number" },
        "costToGo": { "type": "number" },
        "eac": { "type": "number" },
        "timePhasing": { "type": "object", "description": "Monthly forecast values" },
        "distributionMethod": { "type": "string", "enum": ["manual", "even", "front", "back", "custom"] }
      },
      "required": ["sheetId", "costCode"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Record of activities for security and compliance.",
      "type": "object",
      "properties": {
        "enterpriseId": { "type": "string" },
        "projectId": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "object" }
      },
      "required": ["enterpriseId", "userId", "action", "timestamp"]
    },
    "Invitation": {
      "title": "Invitation",
      "description": "A secure invitation for a user to join an enterprise.",
      "type": "object",
      "properties": {
        "enterpriseId": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "token": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "expired"] },
        "invitedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      },
      "required": ["enterpriseId", "email", "token", "status", "invitedBy", "createdAt", "expiresAt"]
    },
    "CostCode": {
      "title": "Cost Code",
      "description": "A project-specific cost code with attributes.",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "User-defined cost code ID" },
        "projectId": { "type": "string" },
        "name": { "type": "string" },
        "enterpriseAttributes": { "type": "object" },
        "projectAttributes": { "type": "object" },
        "eacMethod": { "type": "string", "enum": ["Manual", "Change Management", "ETC Details", "Sub-Contract Management"] },
        "sortOrder": { "type": "number" }
      },
      "required": ["code", "projectId", "sortOrder"]
    },
    "EtcDetail": {
      "title": "ETC Detail",
      "description": "A single line item in an ETC details breakdown.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "costCode": { "type": "string" },
        "calendarId": { "type": "string", "description": "Reference to a project calendar" },
        "item": { "type": "string" },
        "description": { "type": "string" },
        "orderNumber": { "type": "string" },
        "udf1": { "type": "string" },
        "udf2": { "type": "string" },
        "udf3": { "type": "string" },
        "udf4": { "type": "string" },
        "qty": { "type": "number" },
        "unit": { "type": "string" },
        "rate": { "type": "number" },
        "phasingMethod": { "type": "string", "enum": ["Manual", "Auto-Phase"] },
        "phasingStartDate": { "type": "string", "format": "date" },
        "phasingEndDate": { "type": "string", "format": "date" },
        "phasingUnit": { "type": "string", "enum": ["Daily", "Weekly", "Monthly", "Total"] },
        "phasingQty": { "type": "number" },
        "periodValues": { "type": "object" },
        "sortOrder": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "costCode", "sortOrder", "createdAt"]
    },
    "Calendar": {
      "title": "Calendar",
      "description": "Enterprise or Project-specific working day calendar.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "enterpriseId": { "type": "string" },
        "name": { "type": "string" },
        "weekends": { "type": "array", "items": { "type": "number" }, "description": "0-6 (Sun-Sat)" },
        "holidays": { "type": "array", "items": { "type": "string", "format": "date" } }
      },
      "required": ["name"]
    },
    "SavedView": {
      "title": "Saved View",
      "description": "A personalized grid view configuration for a user.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "tableId": { "type": "string" },
        "columns": { "type": "array", "items": { "type": "string" } },
        "gridState": { "type": "array", "description": "Serialized AG-Grid column state" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "tableId", "columns", "userId", "createdAt"]
    },
    "ActualCost": {
      "title": "Actual Cost",
      "description": "A single transaction or record of actual expenditure.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "costCodeId": { "type": "string", "description": "Reference to a CostCode document ID" },
        "item": { "type": "string" },
        "description": { "type": "string" },
        "source": { "type": "string", "enum": ["MAN", "ACC", "FIN"] },
        "cost": { "type": "number" },
        "reportingPeriodId": { "type": "string", "description": "Reference to a reporting period ID" },
        "enterpriseAttributes": { "type": "object" },
        "projectAttributes": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "costCodeId", "cost", "reportingPeriodId", "createdAt"]
    },
    "BaselineBudget": {
      "title": "Baseline Budget",
      "description": "A single record of baseline budget breakdown.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "costCodeId": { "type": "string", "description": "Reference to a CostCode document ID" },
        "item": { "type": "string" },
        "description": { "type": "string" },
        "source": { "type": "string", "enum": ["EST", "CON", "BID"] },
        "amount": { "type": "number" },
        "reportingPeriodId": { "type": "string", "description": "Reference to a reporting period ID" },
        "enterpriseAttributes": { "type": "object" },
        "projectAttributes": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "costCodeId", "amount", "reportingPeriodId", "createdAt"]
    },
    "CostPhasing": {
      "title": "Cost Phasing",
      "description": "Time-phased budget or cost data for a cost code.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "costCodeId": { "type": "string" },
        "type": { "type": "string", "enum": ["baseline", "approved", "eac"] },
        "phasingSource": { "type": "string", "enum": ["Manual", "Auto", "ETC Details", "SubContract"] },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "distribution": { "type": "string", "enum": ["Even", "Bell Curve", "Front load", "Back load", "S-Curve"] },
        "periodValues": { "type": "object", "description": "Map of periodId to cost value" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "costCodeId", "type", "periodValues"]
    },
    "Subcontract": {
      "title": "Subcontract",
      "description": "Represents a subcontract agreement with a vendor.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "enterpriseId": { "type": "string" },
        "orderId": { "type": "string", "description": "User-defined Order ID (max 50)" },
        "orderName": { "type": "string" },
        "orderScope": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Complete", "On Hold"] },
        "paymentType": { "type": "string", "enum": ["LumpSum", "Schedule of Rates", "Re-measurable"] },
        "awardDate": { "type": "string", "format": "date" },
        "vendorId": { "type": "string" },
        "vendorName": { "type": "string" },
        "vendorUsers": { "type": "array", "items": { "type": "string" }, "description": "Emails of users with access" },
        "totalAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "enterpriseId", "orderId", "orderName", "status", "vendorId", "createdAt"]
    },
    "SubcontractLineItem": {
      "title": "Subcontract Line Item",
      "description": "A single line item in a subcontract agreement.",
      "type": "object",
      "properties": {
        "subcontractId": { "type": "string" },
        "projectId": { "type": "string" },
        "itemNo": { "type": "string", "description": "Sequential ID (e.g., 001)" },
        "description": { "type": "string" },
        "qty": { "type": "number" },
        "unit": { "type": "string" },
        "rate": { "type": "number" },
        "total": { "type": "number" },
        "enterpriseAttributes": { "type": "object" },
        "projectAttributes": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subcontractId", "projectId", "itemNo", "description", "qty", "rate", "total", "createdAt"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A progress claim or invoice submitted against a subcontract.",
      "type": "object",
      "properties": {
        "subcontractId": { "type": "string" },
        "projectId": { "type": "string" },
        "invoiceId": { "type": "string", "description": "Sequential ID (e.g., 001)" },
        "description": { "type": "string" },
        "submittedDate": { "type": "string", "format": "date-time" },
        "certifiedDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Draft", "Submitted", "Certified", "Rejected"] },
        "initiator": { "type": "string", "description": "Email of the user who submitted" },
        "claimedAmount": { "type": "number" },
        "certifiedAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subcontractId", "projectId", "invoiceId", "status", "initiator", "createdAt"]
    },
    "InvoiceItem": {
      "title": "Invoice Item",
      "description": "A single line item in an invoice or progress claim.",
      "type": "object",
      "properties": {
        "invoiceId": { "type": "string" },
        "subcontractItemId": { "type": "string" },
        "itemNo": { "type": "string" },
        "qtyClaimedOrPercentage": { "type": "number" },
        "totalClaimed": { "type": "number" },
        "qtyCertifiedOrPercentage": { "type": "number" },
        "totalCertified": { "type": "number" },
        "comment": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["invoiceId", "subcontractItemId", "itemNo", "createdAt"]
    }
  },
  "firestore": {
    "/enterprises/{enterpriseId}": {
      "schema": "Enterprise",
      "description": "Enterprise root documents"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Project documents"
    },
    "/sheets/{sheetId}": {
      "schema": "Sheet",
      "description": "Forecasting sheets"
    },
    "/sheets/{sheetId}/rows/{rowId}": {
      "schema": "ForecastRow",
      "description": "Rows within a sheet"
    },
    "/auditLogs/{logId}": {
      "schema": "AuditLog",
      "description": "System-wide audit logs"
    },
    "/invitations/{invitationId}": {
      "schema": "Invitation",
      "description": "Secure invitations to join enterprises"
    },
    "/costCodes/{costCodeId}": {
      "schema": "CostCode",
      "description": "Project-specific cost codes"
    },
    "/etcDetails/{etcId}": {
      "schema": "EtcDetail",
      "description": "Detailed ETC breakdown items"
    },
    "/calendars/{calendarId}": {
      "schema": "Calendar",
      "description": "Project-specific calendars"
    },
    "/savedViews/{viewId}": {
      "schema": "SavedView",
      "description": "User-specific saved grid views"
    },
    "/actualCosts/{actualCostId}": {
      "schema": "ActualCost",
      "description": "Project-specific actual cost records"
    },
    "/baselineBudgets/{baselineBudgetId}": {
      "schema": "BaselineBudget",
      "description": "Project-specific baseline budget records"
    },
    "/costPhasing/{phasingId}": {
      "schema": "CostPhasing",
      "description": "Time-phased budget or cost data"
    },
    "/subcontracts/{subcontractId}": {
      "schema": "Subcontract",
      "description": "Subcontract header documents"
    },
    "/subcontractLineItems/{itemId}": {
      "schema": "SubcontractLineItem",
      "description": "Subcontract line items"
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Invoices and progress claims"
    },
    "/invoiceItems/{itemId}": {
      "schema": "InvoiceItem",
      "description": "Invoice line items"
    }
  }
}
