{
  "name": "react-example",
  "private": true,
  "version": "1.0.123",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "tsc --noEmit && eslint src --ext .ts,.tsx",
    "lint:boundary": "eslint src --ext .ts,.tsx",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:rules": "firebase emulators:exec --only firestore --project mend-rules-test \"vitest run --config vitest.rules.config.ts\"",
    "test:postgres": "dotenv -e .env.local -- vitest run --config vitest.postgres.config.ts",
    "dev:memory": "VITE_ADAPTER=memory vite --port 5178 --strictPort",
    "dev:postgres": "VITE_ADAPTER=postgres dotenv -e .env.local -- vite --port 5179 --strictPort"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.110.2",
    "@tailwindcss/vite": "^4.1.14",
    "@univerjs/core": "^0.18.0",
    "@univerjs/design": "^0.18.0",
    "@univerjs/docs": "^0.18.0",
    "@univerjs/docs-ui": "^0.18.0",
    "@univerjs/engine-formula": "^0.18.0",
    "@univerjs/engine-render": "^0.18.0",
    "@univerjs/icons": "^1.1.1",
    "@univerjs/sheets": "^0.18.0",
    "@univerjs/sheets-data-validation": "^0.18.0",
    "@univerjs/sheets-data-validation-ui": "^0.18.0",
    "@univerjs/sheets-formula": "^0.18.0",
    "@univerjs/sheets-formula-ui": "^0.18.0",
    "@univerjs/sheets-numfmt": "^0.18.0",
    "@univerjs/sheets-numfmt-ui": "^0.18.0",
    "@univerjs/sheets-table": "^0.18.0",
    "@univerjs/sheets-table-ui": "^0.18.0",
    "@univerjs/sheets-ui": "^0.18.0",
    "@univerjs/ui": "^0.18.0",
    "@vitejs/plugin-react": "^5.0.4",
    "ag-grid-community": "^35.1.0",
    "ag-grid-enterprise": "^35.1.0",
    "ag-grid-react": "^35.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "d3": "^7.9.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.1",
    "express": "^4.21.2",
    "firebase": "^11.0.0",
    "firebase-admin": "^14.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.0",
    "resend": "^6.9.3",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vercel": "^54.20.1",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "@playwright/test": "^1.61.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vercel/node": "^5.8.22",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.4.21",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.6.0",
    "firebase-tools": "^15.23.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.9"
  }
}
