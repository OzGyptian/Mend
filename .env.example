# =============================================================================
# Mend — environment variables (EXAMPLE / template)
#
# Do NOT put real values here. Two ways to get a working .env.local:
#   1. Recommended:  vercel link && vercel env pull .env.local
#   2. Manual:       cp .env.example .env.local  then fill in the values
#
# .env.local is gitignored. NEVER commit real secrets. See ONBOARDING.md.
# =============================================================================

# --- Data adapter -------------------------------------------------------------
# Which storage backend the app talks to:
#   postgres  — Supabase Postgres (normal local development)
#   memory    — in-memory fake adapter (Playwright "acid test", no network)
#   firestore — legacy Firestore adapter (historical)
VITE_ADAPTER=postgres

# --- Supabase: client (VITE_-prefixed → shipped to the browser) ---------------
# The anon key is a public client key (safe in-browser). URL is the project URL.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Supabase: server-side (scripts, migrations) ------------------------------
# SERVICE_ROLE key bypasses row-level security — server/scripts ONLY.
# Never give this the VITE_ prefix (that would leak it to the browser).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email: server ------------------------------------------------------------
# Resend API key for POST /api/invite. Get one at https://resend.com/
RESEND_API_KEY=

# --- Firebase Admin: server ---------------------------------------------------
# Required for POST /api/accept-invite to verify a user's ID token server-side.
# Value = the raw JSON of a service-account key as a SINGLE-LINE string.
#   Firebase Console → Project Settings → Service Accounts → Generate new private key
# NOTE: the Firebase *client* config is NOT an env var — it lives in the committed,
# public firebase-applet-config.json. Only this server-side admin key is secret.
FIREBASE_SERVICE_ACCOUNT_KEY=

# --- Gemini AI (optional) -----------------------------------------------------
# Only needed if AI features are exercised. AI Studio injects this at runtime.
GEMINI_API_KEY=

# --- App URL (optional) -------------------------------------------------------
# Self-referential base URL (links, OAuth callbacks). AI Studio injects at runtime.
APP_URL=

# =============================================================================
# E2E / CI only — NOT needed for a normal `npm run dev`
# =============================================================================
# TEST_EMAIL=
# TEST_PASSWORD=
# BASE_URL=
# VERCEL_BYPASS_SECRET=
